# PhysiCar Nginx Configuration (SIM)

upstream fastapi_backend {
    server 127.0.0.1:8000;
    keepalive 32;
}

upstream novnc_backend {
    server 127.0.0.1:6080;
}

upstream myapp_backend {
    server 127.0.0.1:5000;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ""      close;
}

server {
    listen 80;
    server_name _;
    absolute_redirect off;

    client_max_body_size 500M;

    # ── Studio access-token gate ──
    # Active only for *.trycloudflare.com (see conf.d/pc-token.conf). On the
    # public tunnel host, a valid ?token= mints a cookie and redirects to the
    # same URL without the token; missing/invalid token -> 403. All other hosts
    # (localhost, *.app.github.dev) pass through untouched.
    #
    # The Studio bookmark opens inside a VS Code webview (iframe), so the tunnel
    # is a third-party context — the cookie must be SameSite=None; Secure to be
    # sent on iframe requests. trycloudflare is always https, so Secure is safe.
    if ($pc_action = "deny")  { return 403; }
    if ($pc_action = "grant") { set $grant_target $uri; rewrite ^ /__token_grant last; }

    location = /__token_grant {
        internal;
        add_header Set-Cookie "pc_token=$arg_token; Path=/; HttpOnly; SameSite=None; Secure" always;
        return 302 $grant_target;
    }

    # ── Simulation 3D Viewer (/sim) ──

    location = /sim {
        return 302 /sim/;
    }

    location /sim/ {
        alias /opt/physicar/src/physicar-sim/share/;
        index index.html;
        add_header Cache-Control "no-cache, must-revalidate" always;
    }

    # Sim API (world list, status, switch, pose, route, reset)
    location /sim/api/ {
        proxy_pass http://127.0.0.1:9003/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Connection "";
    }

    # Simulation WebSocket (3D scene streaming)
    location /sim/ws {
        proxy_pass http://127.0.0.1:9002;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400s;
    }

    # ── noVNC (/vnc) ──

    location = /vnc {
        return 302 /vnc/?path=vnc/websockify&autoconnect=true&scale=true;
    }

    location ~ ^/vnc/(.+\.html)$ {
        set $vnc_page $1;
        if ($arg_path = "") {
            return 302 $uri?path=vnc/websockify&autoconnect=true&scale=true;
        }
        proxy_pass http://novnc_backend/$vnc_page$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Accept-Encoding "";
        sub_filter '</head>' '<style>#top_bar,.noVNC_button,.noVNC_panel{display:none!important}html,body,#screen{overflow:hidden!important}</style></head>';
        sub_filter_once on;
    }

    location = /vnc/ {
        if ($arg_path = "") {
            return 302 /vnc/?path=vnc/websockify&autoconnect=true&scale=true;
        }
        proxy_pass http://novnc_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Accept-Encoding "";
        sub_filter '</head>' '<style>#top_bar,.noVNC_button,.noVNC_panel{display:none!important}html,body,#screen{overflow:hidden!important}</style></head>';
        sub_filter_once on;
    }

    location /vnc/ {
        proxy_pass http://novnc_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
    }

    # ── MyApp (:5000) ──

    location = /myapp { return 302 /myapp/; }

    location /myapp/ {
        proxy_pass http://myapp_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        proxy_set_header If-Modified-Since "";
        proxy_set_header If-None-Match "";

        proxy_buffering off;
        proxy_request_buffering off;
        chunked_transfer_encoding off;
        gzip off;

        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        add_header Pragma "no-cache" always;
        add_header Expires "0" always;
        add_header X-Accel-Buffering "no" always;

        proxy_connect_timeout 5s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
        error_page 502 503 504 = @myapp_offline;
    }

    location @myapp_offline {
        default_type text/html;
        charset utf-8;
        add_header Cache-Control "no-store" always;
        add_header X-MyApp-Status "offline" always;
        return 200 '<!DOCTYPE html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>MyApp</title><style>html,body{margin:0;height:100%;background:#0d0d10;color:#aaa;font-family:system-ui,sans-serif}body{display:flex;align-items:center;justify-content:center;text-align:center}code{background:#222;padding:2px 6px;border-radius:4px;color:#b388ff}.box{max-width:520px;padding:24px}.spin{display:inline-block;width:14px;height:14px;border:2px solid #333;border-top-color:#888;border-radius:50%;animation:s 1s linear infinite;vertical-align:middle;margin-right:8px}@keyframes s{to{transform:rotate(360deg)}}</style></head><body><div class="box"><h2>MyApp is not running</h2><p>It will auto-start on port <code>5000</code>.</p><p style="color:#666"><span class="spin"></span>Auto-reloading…</p></div><script>setInterval(async()=>{try{const r=await fetch(location.pathname+(location.pathname.endsWith("/")?"":"/")+"?_t="+Date.now(),{cache:"no-store"});if(r.headers.get("X-MyApp-Status")!=="offline")location.reload()}catch(e){}},2000);</script></body></html>';
    }

    # ── Studio ──

    location = /studio {
        alias /opt/physicar/src/physicar-ros/physicar_webserver/static/studio.html;
        default_type text/html;
        add_header Cache-Control "no-cache" always;
    }

    # ── Home (FastAPI webserver) ──

    location / {
        proxy_pass http://fastapi_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        proxy_buffering off;
        proxy_request_buffering off;
        proxy_cache off;
        chunked_transfer_encoding off;
        gzip off;
        add_header X-Accel-Buffering no always;

        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        error_page 502 503 504 = @fastapi_offline;
    }

    location @fastapi_offline {
        default_type text/html;
        charset utf-8;
        add_header Cache-Control "no-store" always;
        return 200 '<!DOCTYPE html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>PhysiCar</title><style>html,body{margin:0;height:100%;background:#0d0d10;color:#888;font-family:system-ui,sans-serif}body{display:flex;align-items:center;justify-content:center}.spin{width:42px;height:42px;border:4px solid #2a2a33;border-top-color:#666;border-radius:50%;animation:s 1s linear infinite}@keyframes s{to{transform:rotate(360deg)}}</style></head><body><div class="spin"></div><script>setInterval(async()=>{try{const r=await fetch("/health?t="+Date.now(),{cache:"no-store"});if(r.ok)location.reload()}catch(e){}},2000);</script></body></html>';
    }
}
