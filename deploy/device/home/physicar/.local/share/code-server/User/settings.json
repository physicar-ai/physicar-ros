{
  "chat.disableAIFeatures": true,
  "code-runner.runInTerminal": true,
  "code-runner.executorMap": {"shellscript": "cd $dir && ./$fileName", "python": "cd $dir && python3 -u $fileName"},
  "chat.sendElementsToChat.enabled": false,
  "workbench.startupEditor": "none",
  "workbench.welcomePage.walkthroughs.openOnInstall": false,
  "editor.fontSize": 14,
  "editor.tabSize": 4,
  "files.autoSave": "afterDelay",
  "python.defaultInterpreterPath": "/usr/bin/python3",
  "python.analysis.extraPaths": [
    "/opt/ros/jazzy/lib/python3.12/site-packages",
    "/opt/physicar/install/physicar_interfaces/lib/python3.12/site-packages"
  ],
  "simpleBrowser.focusLockIndicator.enabled": false,
  "telemetry.telemetryLevel": "off",
  "chat.viewSessions.orientation": "stacked",
  "terminal.integrated.initialHint": false,
  "remote.autoForwardPorts": false,
  "remote.otherPortsAttributes": {"onAutoForward": "silent"},
  "update.showReleaseNotes": false,
  "extensions.ignoreRecommendations": true,
  "workbench.tips.enabled": false,
  "explorer.compactFolders": false,
  "security.workspace.trust.enabled": false
}
