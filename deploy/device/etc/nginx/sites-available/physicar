        proxy_set_header Accept-Encoding "";
        sub_filter '</head>' '<style>#top_bar,.noVNC_button,.noVNC_panel{display:none!important}html,body,#screen{overflow:hidden!important}</style></head>';
        sub_filter_once on;
    }

    location = /vnc/ {
        if ($arg_path = "") {
            return 302 /vnc/?path=vnc/websockify&autoconnect=true&scale=true;
        }
        if ($auth_ok = 0) {
            return 302 /login?next=/vnc;
