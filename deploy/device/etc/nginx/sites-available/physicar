# PhysiCar Nginx Configuration (Host)
# All services on single port 80/443:
#   code-server(/), App(/app), PhysiCar pages+API(/deepracer +
#   explicit FastAPI prefixes), noVNC(/vnc), MyApp(/myapp)
# Authentication: nginx-managed (geo IP, cookie, query string)
#
# Two server blocks share an identical set of locations:
#   1. server _              — default, self-signed cert, serves
#                              physicar.local / hostname.local / raw IP.
#   2. device.physicar.ai
#      *.preview.physicar.ai — Let's Encrypt cert, used by Chromium-based
#                              webviews (Service Workers require trusted TLS).
#
# Both cert pairs are guaranteed to exist on disk:
#   /etc/nginx/ssl/physicar.{crt,key}  — self-signed, generated at setup
#   /etc/nginx/ssl/le.{crt,key}        — initially copies of the self-signed
#                                        pair, replaced in-place by the cert
#                                        fetcher in physicar.sh when a real
#                                        Let's Encrypt cert is downloaded.
#
# / (code-server) auto-redirects hotspot clients to https://device.physicar.ai/
# only when /run/physicar/le-cert-valid exists (i.e. fetcher has installed
# a real, non-expired LE cert).  Otherwise users stay on the self-signed
# host (browser warning, but no redirect to a broken LE block).

# ─────────────────────────────────────────────────────────────────────────
# Captive-portal spoofing — convince client OSes the network has internet.
# dnsmasq resolves these domains to 10.42.0.1; nginx returns the responses
# each OS expects. Only affects hotspot clients (no real DNS hijacking).
# ─────────────────────────────────────────────────────────────────────────
server {
    listen 80;
    server_name
        www.msftconnecttest.com msftconnecttest.com
        www.msftncsi.com msftncsi.com
        captive.apple.com
        connectivitycheck.gstatic.com
        clients3.google.com
        detectportal.firefox.com
        connectivity-check.ubuntu.com;

    # Windows: GET /connecttest.txt → "Microsoft Connect Test"
    location = /connecttest.txt {
        return 200 "Microsoft Connect Test";
    }
    # Windows (legacy NCSI): GET /ncsi.txt → "Microsoft NCSI"
    location = /ncsi.txt {
        return 200 "Microsoft NCSI";
    }
    # Windows: GET /redirect → 200 (not a redirect)
    location = /redirect {
        return 200 "OK";
    }
    # macOS / iOS: GET /hotspot-detect.html → HTML with "Success"
    location = /hotspot-detect.html {
        return 200 "<HTML><HEAD><TITLE>Success</TITLE></HEAD><BODY>Success</BODY></HTML>";
    }
    # Android / Chrome OS: GET /generate_204 → HTTP 204
    location = /generate_204 {
        return 204;
    }
    # Firefox: GET /success.txt → "success\n"
    location = /success.txt {
        return 200 "success\n";
    }
    # Ubuntu: GET / → HTTP 204
    location = / {
        return 204;
    }
    # Catch-all for any other path on these domains
    location / {
        return 200 "OK";
    }
}

upstream fastapi_backend {
    server 127.0.0.1:8000;
    keepalive 32;
}

upstream code_web {
    server 127.0.0.1:8080;
}

upstream novnc_backend {
    server 127.0.0.1:6080;
}

upstream myapp_backend {
    server 127.0.0.1:5000;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ""      close;
}

# ── Authentication ──

# IP-based exemption (trusted networks)
geo $auth_ip_exempt {
    default    0;
    127.0.0.0/8   1;   # localhost
    10.42.0.0/24  1;   # WiFi hotspot clients
}

# Cookie-based auth (cookie value = "<PASSWORD>.<BOOT_TOKEN>")
# BOOT_TOKEN is regenerated on every host boot (see physicar.sh), so any
# previously-issued cookie becomes invalid → users must log in again.
map $cookie_physicar_auth $auth_by_cookie {
    include /etc/nginx/conf.d/physicar_session.map;
    default 0;
}

# Query string auth (?password=xxx) — for API clients (curl, scripts).
# This stays valid across reboots since it doesn't carry a boot token.
map $arg_password $auth_by_query {
    include /etc/nginx/conf.d/physicar_password.map;
    default 0;
}

# Header auth (X-Password: xxx) — same use case as the query param but
# avoids leaking the password in URLs / access logs.  Same map, same
# reboot-survivability rules.
map $http_x_password $auth_by_header {
    include /etc/nginx/conf.d/physicar_password.map;
    default 0;
}

# Combined: any method passes (string contains "1")
map "$auth_ip_exempt$auth_by_cookie$auth_by_query$auth_by_header" $auth_ok {
    ~1       1;
    default  0;
}

# ─────────────────────────────────────────────────────────────────────────
# Default server block — self-signed cert.
# Catches physicar.local, hostname.local, raw IP, anything not matching
# the LE server_name list below.
# ─────────────────────────────────────────────────────────────────────────

server {
    listen 80 default_server;
    listen 443 ssl http2 default_server;
    server_name _;
    absolute_redirect off;

    client_max_body_size 500M;

    ssl_certificate /etc/nginx/ssl/physicar.crt;
    ssl_certificate_key /etc/nginx/ssl/physicar.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    # Force HTTPS for non-localhost HTTP requests (browsers only).
    # localhost/127.0.0.1 stays on HTTP so kiosk Chromium and container
    # clients can keep using http://localhost without cert issues.
    # API clients (curl, etc.) are not redirected.
    if ($scheme = "http") {
        set $force_https "H";
    }
    if ($host ~* "^(localhost|127\.0\.0\.1)") {
        set $force_https "${force_https}L";
    }
    if ($http_accept !~* "text/html") {
        set $force_https "${force_https}A";
    }
    if ($force_https = "H") {
        return 301 https://$host$request_uri;
    }

    # Redirect physicar.local → actual hostname.local (production, browsers only)
    # API clients (Accept: application/json etc.) are served directly
    set $redirect_check "";
    if ($host = "physicar.local") {
        set $redirect_check "H";
    }
    if ($http_accept ~* "text/html") {
        set $redirect_check "${redirect_check}B";
    }
    set $canonical_host "${hostname}.local";
    if ($canonical_host = "physicar.local") {
        set $redirect_check "";
    }
    if ($redirect_check = "HB") {
        return 302 $scheme://$canonical_host$request_uri;
    }

    # ── Public (no auth) ──

    location = /login {
        add_header Cache-Control "no-store";
        alias /opt/physicar/src/physicar-ros/physicar_webserver/static/login.html;
        default_type text/html;
    }

    location = /login/logo.png {
        alias /opt/physicar/src/physicar-ros/physicar_webserver/static/img/logo.png;
        add_header Cache-Control "public, max-age=86400";
    }

    location = /auth/nonce {
        add_header Cache-Control "no-store" always;
        default_type text/plain;
        root /etc/nginx/html;
        try_files /boot_token =404;
    }

    location = /health {
        proxy_pass http://fastapi_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Connection "";
    }

    # ── code-server (/) ──
    # Root serves code-server; the PhysiCar app lives on the explicit
    # prefixes below. Legacy /code URLs redirect to the new root.

    location = /code { return 302 /$is_args$args; }
    location /code/  { return 302 /$is_args$args; }

    location = / {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }

        # Bare page load → open the workspace. Requests WITH a query string
        # (?folder=, ?reconnectionToken= WebSocket, …) must pass through.
        if ($args = "") {
            return 302 /?folder=/home/physicar/physicar_ws;
        }

        # Auto-redirect hotspot clients to device.physicar.ai when the
        # fetcher has a valid LE cert installed (flag file present).
        # Otherwise serve self-signed in place (browser warning, but no
        # SW; users opt into manual Continue).
        set $code_redir "";
        if (-f /run/physicar/le-cert-valid) { set $code_redir "${code_redir}V"; }
        if ($remote_addr ~ "^10\.42\.0\.") { set $code_redir "${code_redir}H"; }
        if ($code_redir = "VH") {
            return 302 https://device.physicar.ai$request_uri;
        }

        proxy_pass http://code_web;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
    }

    location / {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }

        # Hotspot → LE-host redirect (same rule as `location = /`).
        set $code_redir "";
        if (-f /run/physicar/le-cert-valid) { set $code_redir "${code_redir}V"; }
        if ($remote_addr ~ "^10\.42\.0\.") { set $code_redir "${code_redir}H"; }
        if ($code_redir = "VH") {
            return 302 https://device.physicar.ai$request_uri;
        }

        proxy_pass http://code_web;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
    }

    # ── noVNC (/vnc) ──

    location = /vnc {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        return 302 /vnc/?path=vnc/websockify&autoconnect=true&scale=true;
    }

    location ~ ^/vnc/(.+\.html)$ {
        set $vnc_page $1;
        if ($arg_path = "") {
            return 302 $uri?path=vnc/websockify&autoconnect=true&scale=true;
        }
        if ($auth_ok = 0) {
            return 302 /login?next=/vnc;
        }
        proxy_pass http://novnc_backend/$vnc_page$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Accept-Encoding "";
        sub_filter '</head>' '<style>#top_bar,.noVNC_button,.noVNC_panel{display:none!important}html,body,#screen{overflow:hidden!important}</style></head>';
        sub_filter_once on;
    }

    location = /vnc/ {
        if ($arg_path = "") {
            return 302 /vnc/?path=vnc/websockify&autoconnect=true&scale=true;
        }
        if ($auth_ok = 0) {
            return 302 /login?next=/vnc;
        }
        proxy_pass http://novnc_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Accept-Encoding "";
        sub_filter '</head>' '<style>#top_bar,.noVNC_button,.noVNC_panel{display:none!important}html,body,#screen{overflow:hidden!important}</style></head>';
        sub_filter_once on;
    }

    location /vnc/ {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://novnc_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
    }

    # ── MyApp (:5000) ──

    location = /myapp { return 302 /myapp/; }

    location /myapp/ {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://myapp_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;

        proxy_set_header If-Modified-Since "";
        proxy_set_header If-None-Match "";

        # ── PhysiCar session helper auto-injection ──
        # Student pages need zero setup: injects window.physicarSession.token()
        # (reads the physicar_session cookie). Only HTML is rewritten
        # (sub_filter_types defaults to text/html) — SSE/MJPEG pass untouched.
        proxy_set_header Accept-Encoding "";
        sub_filter_once on;
        sub_filter '<head>' '<head><script src="/static/js/physicar-session.js"></script>';

        proxy_buffering off;
        proxy_request_buffering off;
        chunked_transfer_encoding off;
        gzip off;

        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        add_header Pragma "no-cache" always;
        add_header Expires "0" always;
        add_header X-Accel-Buffering "no" always;

        proxy_connect_timeout 5s;
        # No send/read limits: student apps may hold quiet WebSocket/SSE
        # connections open indefinitely (connect stays 5s for the offline page)
        proxy_send_timeout 86400s;
        proxy_read_timeout 86400s;
        error_page 502 503 504 = @myapp_offline;
    }

    location @myapp_offline {
        default_type text/html;
        charset utf-8;
        add_header Cache-Control "no-store" always;
        add_header X-MyApp-Status "offline" always;
        return 200 '<!DOCTYPE html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>MyApp</title><style>html,body{margin:0;height:100%;background:#0d0d10;color:#aaa;font-family:system-ui,sans-serif}body{display:flex;align-items:center;justify-content:center;text-align:center}code{background:#222;padding:2px 6px;border-radius:4px;color:#b388ff}.box{max-width:520px;padding:24px}.spin{display:inline-block;width:14px;height:14px;border:2px solid #333;border-top-color:#888;border-radius:50%;animation:s 1s linear infinite;vertical-align:middle;margin-right:8px}@keyframes s{to{transform:rotate(360deg)}}</style></head><body><div class="box"><h2>MyApp is not running</h2><p>It will auto-start on port <code>5000</code>.</p><p style="color:#666"><span class="spin"></span>Auto-reloading…</p></div><script>(function(){var n=0,t=null;function arm(ms){t=setTimeout(chk,ms)}async function chk(){t=null;if(document.hidden)return;try{var r=await fetch(location.pathname+(location.pathname.endsWith("/")?"":"/")+"?_t="+Date.now(),{cache:"no-store"});if(r.headers.get("X-MyApp-Status")!=="offline"){location.reload();return}}catch(e){}n++;arm(n<15?2000:15000)}document.addEventListener("visibilitychange",function(){if(!document.hidden&&!t)chk()});arm(2000)})();</script></body></html>';
    }


    # Legacy path (pre-rename bookmarks). /app itself is served by FastAPI
    # (with cache-busted asset URLs) via the explicit-prefix location below.
    location = /studio { return 302 /app; }


    # ── Streaming drive control (WebSocket write streams) ──
    # Regex locations are order-sensitive — this must precede the FastAPI catch-all
    location ~ ^/(speed|steering)/stream$ {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://fastapi_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_read_timeout 86400s;
    }

    # ── Audio realtime PCM16 stream (WebSocket) ──
    location = /audio/stream {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://fastapi_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_read_timeout 86400s;
    }

    # ── PhysiCar app (FastAPI :8000) — pages + APIs ──
    # `/` belongs to code-server, so every FastAPI route is listed here
    # explicitly: pages (/app /deepracer), assets
    # (/static /favicon.ico /docs /redoc /openapi.json) and APIs. Add new
    # top-level FastAPI prefixes to this list when introducing them.
    location ~ ^/(app|deepracer|static|docs|redoc|openapi\.json|favicon\.ico|info|auth|network|calibration|teleop|settings|kiosk|states|speed|steering|camera|lidar|audio|battery|imu|odom|log|api)(/|$) {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://fastapi_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        # SSE / MJPEG streaming support
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_cache off;
        chunked_transfer_encoding off;
        gzip off;
        add_header X-Accel-Buffering no always;

        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        error_page 502 503 504 = @fastapi_offline;
    }

    location @fastapi_offline {
        default_type text/html;
        charset utf-8;
        add_header Cache-Control "no-store" always;
        # Subresources (CSS/JS/fetch) must FAIL, not receive this HTML with a
        # 200 — a stylesheet that "loads" as HTML fires no error event, so the
        # pages' boot-race reload guard never kicks in and the page stays
        # broken. Only document navigations get the spinner page.
        if ($http_accept !~* "text/html") { return 503; }
        return 200 '<!DOCTYPE html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>PhysiCar</title><style>html,body{margin:0;height:100%;background:#0d0d10;color:#888;font-family:system-ui,sans-serif}body{display:flex;align-items:center;justify-content:center}.spin{width:42px;height:42px;border:4px solid #2a2a33;border-top-color:#666;border-radius:50%;animation:s 1s linear infinite}@keyframes s{to{transform:rotate(360deg)}}</style></head><body><div class="spin"></div><script>(function(){var n=0,t=null;function arm(ms){t=setTimeout(chk,ms)}async function chk(){t=null;if(document.hidden)return;try{var r=await fetch("/health?t="+Date.now(),{cache:"no-store"});if(r.ok){location.reload();return}}catch(e){}n++;arm(n<15?2000:15000)}document.addEventListener("visibilitychange",function(){if(!document.hidden&&!t)chk()});arm(2000)})();</script></body></html>';
    }
}

# ─────────────────────────────────────────────────────────────────────────
# Let's Encrypt server block — same locations, served with the LE cert.
# le.{crt,key} are kept in sync by physicar.sh (initialized as copies of the
# self-signed pair so nginx always starts).
# ─────────────────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name device.physicar.ai *.preview.physicar.ai;
    absolute_redirect off;

    client_max_body_size 500M;

    ssl_certificate /etc/nginx/ssl/le.crt;
    ssl_certificate_key /etc/nginx/ssl/le.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ecdh_curve prime256v1;

    # ── Public (no auth) ──

    location = /login {
        add_header Cache-Control "no-store";
        alias /opt/physicar/src/physicar-ros/physicar_webserver/static/login.html;
        default_type text/html;
    }

    location = /login/logo.png {
        alias /opt/physicar/src/physicar-ros/physicar_webserver/static/img/logo.png;
        add_header Cache-Control "public, max-age=86400";
    }

    location = /auth/nonce {
        add_header Cache-Control "no-store" always;
        default_type text/plain;
        root /etc/nginx/html;
        try_files /boot_token =404;
    }

    location = /health {
        proxy_pass http://fastapi_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Connection "";
    }

    # ── code-server (/) ──
    # No hotspot redirect here — clients reaching us via device.physicar.ai
    # are already on the LE-trusted host. Legacy /code URLs redirect to /.

    location = /code { return 302 /$is_args$args; }
    location /code/  { return 302 /$is_args$args; }

    location = / {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }

        # Bare page load → open the workspace. Requests WITH a query string
        # (?folder=, ?reconnectionToken= WebSocket, …) must pass through.
        if ($args = "") {
            return 302 /?folder=/home/physicar/physicar_ws;
        }

        proxy_pass http://code_web;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
    }

    location / {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://code_web;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
    }

    # ── noVNC (/vnc) ──

    location = /vnc {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        return 302 /vnc/?path=vnc/websockify&autoconnect=true&scale=true;
    }

    location ~ ^/vnc/(.+\.html)$ {
        set $vnc_page $1;
        if ($arg_path = "") {
            return 302 $uri?path=vnc/websockify&autoconnect=true&scale=true;
        }
        if ($auth_ok = 0) {
            return 302 /login?next=/vnc;
        }
        proxy_pass http://novnc_backend/$vnc_page$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Accept-Encoding "";
        sub_filter '</head>' '<style>#top_bar,.noVNC_button,.noVNC_panel{display:none!important}html,body,#screen{overflow:hidden!important}</style></head>';
        sub_filter_once on;
    }

    location = /vnc/ {
        if ($arg_path = "") {
            return 302 /vnc/?path=vnc/websockify&autoconnect=true&scale=true;
        }
        if ($auth_ok = 0) {
            return 302 /login?next=/vnc;
        }
        proxy_pass http://novnc_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Accept-Encoding "";
        sub_filter '</head>' '<style>#top_bar,.noVNC_button,.noVNC_panel{display:none!important}html,body,#screen{overflow:hidden!important}</style></head>';
        sub_filter_once on;
    }

    location /vnc/ {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://novnc_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
    }

    # ── MyApp (:5000) ──

    location = /myapp { return 302 /myapp/; }

    location /myapp/ {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://myapp_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;

        proxy_set_header If-Modified-Since "";
        proxy_set_header If-None-Match "";

        # ── PhysiCar session helper auto-injection ──
        # Student pages need zero setup: injects window.physicarSession.token()
        # (reads the physicar_session cookie). Only HTML is rewritten
        # (sub_filter_types defaults to text/html) — SSE/MJPEG pass untouched.
        proxy_set_header Accept-Encoding "";
        sub_filter_once on;
        sub_filter '<head>' '<head><script src="/static/js/physicar-session.js"></script>';

        proxy_buffering off;
        proxy_request_buffering off;
        chunked_transfer_encoding off;
        gzip off;

        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        add_header Pragma "no-cache" always;
        add_header Expires "0" always;
        add_header X-Accel-Buffering "no" always;

        proxy_connect_timeout 5s;
        # No send/read limits: student apps may hold quiet WebSocket/SSE
        # connections open indefinitely (connect stays 5s for the offline page)
        proxy_send_timeout 86400s;
        proxy_read_timeout 86400s;
        error_page 502 503 504 = @myapp_offline;
    }

    location @myapp_offline {
        default_type text/html;
        charset utf-8;
        add_header Cache-Control "no-store" always;
        add_header X-MyApp-Status "offline" always;
        return 200 '<!DOCTYPE html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>MyApp</title><style>html,body{margin:0;height:100%;background:#0d0d10;color:#aaa;font-family:system-ui,sans-serif}body{display:flex;align-items:center;justify-content:center;text-align:center}code{background:#222;padding:2px 6px;border-radius:4px;color:#b388ff}.box{max-width:520px;padding:24px}.spin{display:inline-block;width:14px;height:14px;border:2px solid #333;border-top-color:#888;border-radius:50%;animation:s 1s linear infinite;vertical-align:middle;margin-right:8px}@keyframes s{to{transform:rotate(360deg)}}</style></head><body><div class="box"><h2>MyApp is not running</h2><p>It will auto-start on port <code>5000</code>.</p><p style="color:#666"><span class="spin"></span>Auto-reloading…</p></div><script>(function(){var n=0,t=null;function arm(ms){t=setTimeout(chk,ms)}async function chk(){t=null;if(document.hidden)return;try{var r=await fetch(location.pathname+(location.pathname.endsWith("/")?"":"/")+"?_t="+Date.now(),{cache:"no-store"});if(r.headers.get("X-MyApp-Status")!=="offline"){location.reload();return}}catch(e){}n++;arm(n<15?2000:15000)}document.addEventListener("visibilitychange",function(){if(!document.hidden&&!t)chk()});arm(2000)})();</script></body></html>';
    }


    # Legacy path (pre-rename bookmarks). /app itself is served by FastAPI
    # (with cache-busted asset URLs) via the explicit-prefix location below.
    location = /studio { return 302 /app; }


    # ── Streaming drive control (WebSocket write streams) ──
    # Regex locations are order-sensitive — this must precede the FastAPI catch-all
    location ~ ^/(speed|steering)/stream$ {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://fastapi_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_read_timeout 86400s;
    }

    # ── Audio realtime PCM16 stream (WebSocket) ──
    location = /audio/stream {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://fastapi_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        # strip permessage-deflate offers: CF edge (h2 WS) mangles compressed
        # frames -> "Invalid frame header" in browsers; payloads are tiny anyway
        proxy_set_header Sec-WebSocket-Extensions "";
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_read_timeout 86400s;
    }

    # ── PhysiCar app (FastAPI :8000) — pages + APIs ──
    # `/` belongs to code-server, so every FastAPI route is listed here
    # explicitly: pages (/app /deepracer), assets
    # (/static /favicon.ico /docs /redoc /openapi.json) and APIs. Add new
    # top-level FastAPI prefixes to this list when introducing them.
    location ~ ^/(app|deepracer|static|docs|redoc|openapi\.json|favicon\.ico|info|auth|network|calibration|teleop|settings|kiosk|states|speed|steering|camera|lidar|audio|battery|imu|odom|log|api)(/|$) {
        if ($auth_ok = 0) {
            return 302 /login?next=$uri;
        }
        proxy_pass http://fastapi_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        # SSE / MJPEG streaming support
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_cache off;
        chunked_transfer_encoding off;
        gzip off;
        add_header X-Accel-Buffering no always;

        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        error_page 502 503 504 = @fastapi_offline;
    }

    location @fastapi_offline {
        default_type text/html;
        charset utf-8;
        add_header Cache-Control "no-store" always;
        # Subresources (CSS/JS/fetch) must FAIL, not receive this HTML with a
        # 200 — a stylesheet that "loads" as HTML fires no error event, so the
        # pages' boot-race reload guard never kicks in and the page stays
        # broken. Only document navigations get the spinner page.
        if ($http_accept !~* "text/html") { return 503; }
        return 200 '<!DOCTYPE html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>PhysiCar</title><style>html,body{margin:0;height:100%;background:#0d0d10;color:#888;font-family:system-ui,sans-serif}body{display:flex;align-items:center;justify-content:center}.spin{width:42px;height:42px;border:4px solid #2a2a33;border-top-color:#666;border-radius:50%;animation:s 1s linear infinite}@keyframes s{to{transform:rotate(360deg)}}</style></head><body><div class="spin"></div><script>(function(){var n=0,t=null;function arm(ms){t=setTimeout(chk,ms)}async function chk(){t=null;if(document.hidden)return;try{var r=await fetch("/health?t="+Date.now(),{cache:"no-store"});if(r.ok){location.reload();return}}catch(e){}n++;arm(n<15?2000:15000)}document.addEventListener("visibilitychange",function(){if(!document.hidden&&!t)chk()});arm(2000)})();</script></body></html>';
    }
