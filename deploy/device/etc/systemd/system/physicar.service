[Unit]
Description=Physicar Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=physicar
Group=physicar
EnvironmentFile=-/opt/physicar/userdata/.env
ExecStart=/opt/physicar/src/physicar-ros/deploy/device/physicar.sh
RemainAfterExit=yes
TimeoutStartSec=0
TimeoutStopSec=3

[Install]
WantedBy=multi-user.target
