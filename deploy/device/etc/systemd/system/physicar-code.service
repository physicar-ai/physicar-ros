[Unit]
Description=PhysiCar code-server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=physicar
Group=physicar
Environment=HOME=/home/physicar
ExecStart=/usr/local/bin/code-server \
    --bind-addr 127.0.0.1:8080 \
    --auth none \
    --disable-telemetry \
    --disable-update-check \
    --proxy-domain preview.physicar.ai \
    /opt/physicar
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
