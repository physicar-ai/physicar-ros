<?xml version="1.0" encoding="UTF-8"?>
<!--
  CycloneDDS config for all device ROS nodes.

  Every PhysiCar topic is machine-local. Binding lo with unicast-only
  discovery (no multicast, explicit 127.0.0.1 peers) keeps hotspot/wifi/eth
  interface changes invisible to DDS. MaxAutoParticipantIndex bounds the
  unicast discovery port scan; ~14 system participants plus student nodes
  fit well under 100.
-->
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain Id="any">
    <General>
      <Interfaces>
        <NetworkInterface name="lo"/>
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
    </General>
    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>100</MaxAutoParticipantIndex>
      <Peers>
        <Peer address="127.0.0.1"/>
      </Peers>
    </Discovery>
  </Domain>
</CycloneDDS>
