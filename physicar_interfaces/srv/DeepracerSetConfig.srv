# DeepRacer configuration service
# Allows runtime configuration changes for the deepracer node

# Request
string key              # Configuration key: 'action_selection', 'pan', 'tilt', 'all'
string string_value     # String value (for 'action_selection': 'greedy' or 'stochastic')
float64 float_value     # Float value (for 'pan', 'tilt' in degrees)
bool save_to_file       # If true, save current config to /opt/physicar/deepracer/config.json

---
# Response
bool success
string message
