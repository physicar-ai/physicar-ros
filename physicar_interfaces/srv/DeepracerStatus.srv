# Get current DeepRacer node status

---

# Response
bool model_loaded           # True if a model is loaded
bool inference_running      # True if inference is actively running
string model_name           # Name of active model (empty if none)
string model_path           # Full path to active model
int32 action_count          # Number of actions in active model's action space
string action_space_json    # Active model's action space as JSON array
string loaded_models_json   # JSON array of all loaded model names
float32 inference_rate      # Current inference rate (Hz)
int64 inference_count       # Total inferences since start
string last_action          # Last action taken as JSON {"index":, "speed":, "steering_angle":}

# Configuration
string action_selection_mode  # greedy, stochastic, mean
string config_source          # default, json_file, ros_params
float32 camera_pan            # Camera pan setting (degrees)
float32 camera_tilt           # Camera tilt setting (degrees)
float32 speed_percent         # Speed multiplier percent (50 ~ 150)
