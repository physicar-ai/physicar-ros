# Load a DeepRacer model for inference
# Models are stored in /opt/physicar/deepracer/models/<model_name>/

# Request
string model_name    # Name of model directory (e.g., "physicar-test-model")

---

# Response
bool success                    # True if model loaded successfully
string message                  # Status message or error description
string model_path               # Full path to loaded model
string action_space_json        # Action space as JSON array [{"speed":, "steering_angle":}, ...]
