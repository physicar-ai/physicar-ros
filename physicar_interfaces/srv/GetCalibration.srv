# GetCalibration.srv
# Get current calibration values
#
# Usage:
#   ros2 service call /physicar_driver/get_calibration physicar_interfaces/srv/GetCalibration "{}"

# Request (empty)
---
# Response
bool success
string message

# Max values
float64 max_steering       # ± degrees (wheel angle)
float64 max_speed          # ± m/s
float64 max_pan            # ± degrees
float64 max_tilt           # ± degrees

# Center offsets (degrees from 90°)
float64 steering_center
float64 pan_center
float64 tilt_center

# ESC direction
bool reverse_direction   # true: 90° above = forward (reversed ESC)

# Source of current calibration
string source           # 'json_file', 'yaml_params', or 'defaults'
string calibration_json # Full calibration as JSON string
