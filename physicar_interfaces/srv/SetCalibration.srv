# SetCalibration.srv
# Set calibration values for a specific servo channel and save to file

# Request
string channel          # 'steering', 'speed', 'pan', 'tilt', 'reverse', 'emergency', or 'all'
float64 max_value       # max limit (degrees or m/s for speed), ignored if channel='all', 'reverse', or 'emergency'
float64 center_value    # center offset (degrees), ignored if channel='all', 'speed', 'reverse', or 'emergency'
bool bool_value         # for reverse_direction or emergency_enabled
bool save_to_file       # true: save to /opt/physicar/calibration.json after applying
---
# Response
bool success
string message
string current_calibration_json   # Current calibration state as JSON string
