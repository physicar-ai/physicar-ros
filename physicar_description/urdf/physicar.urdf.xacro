<?xml version="1.0"?>
<!--
  PhysiCar Robot URDF - Main Entry Point
  Copyright 2025 PhysiCar AI
  
  Ackermann steering vehicle with:
  - Front wheel drive (FWD) + Ackermann steering
  - LiDAR sensor
  - Pan-Tilt camera system
  - IMU sensor
-->

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="physicar">

  <!-- Include macro definitions -->
  <xacro:include filename="$(find physicar_description)/urdf/common_properties.xacro"/>
  <xacro:include filename="$(find physicar_description)/urdf/physicar_macros.xacro"/>

  <!-- Vehicle parameters -->
  <xacro:property name="wheelbase" value="0.18"/>
  <xacro:property name="track_width" value="0.16"/>            <!-- TF: actual wheel center distance (measured) -->
  <xacro:property name="visual_track_width" value="0.20"/>    <!-- Visual: mesh original position -->
  <xacro:property name="wheel_radius" value="0.0375"/>
  <xacro:property name="wheel_width" value="0.035"/>

  <!-- ========== BASE LINK ========== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.3"/>
      <inertia ixx="0.00234" ixy="0" ixz="0" iyy="0.01092" iyz="0" izz="0.01092"/>
    </inertial>

    <visual name="base_visual">
      <origin xyz="0.1371 0 -0.0115" rpy="-0.018 0 1.5707"/>
      <geometry>
        <mesh filename="file://$(find physicar_description)/meshes/BaseReduced.dae"/>
      </geometry>
    </visual>

    <visual name="top_visual">
      <origin xyz="0.0 0.0 0.065" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="file://$(find physicar_description)/meshes/TopReduced.dae"/>
      </geometry>
    </visual>

    <collision name="base_collision">
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <box size="0.27 0.09 0.12"/>
      </geometry>
    </collision>
  </link>

  <!-- ========== LIDAR ========== -->
  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>

    <visual name="lidar_visual">
      <origin xyz="0.0 0.0 -0.03" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find physicar_description)/meshes/STL27L.dae"/>
      </geometry>
    </visual>

    <collision name="lidar_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="-0.027 0.0 0.1625" rpy="0 0 0"/>
  </joint>

  <!-- ========== PAN-TILT CAMERA SYSTEM ========== -->
  <!-- Pan Link (Z-axis rotation) -->
  <link name="camera_pan_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>

    <visual name="pan_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find physicar_description)/meshes/ServoPan.dae"/>
      </geometry>
    </visual>

    <collision name="pan_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="camera_pan_link"/>
    <origin xyz="0.05 0.0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.7854" upper="0.7854" effort="10" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Tilt Link (Y-axis rotation) -->
  <link name="camera_tilt_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.03"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000005"/>
    </inertial>

    <visual name="tilt_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find physicar_description)/meshes/ServoTilt.dae"/>
      </geometry>
    </visual>

    <collision name="tilt_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_tilt_joint" type="revolute">
    <parent link="camera_pan_link"/>
    <child link="camera_tilt_link"/>
    <origin xyz="0.025 0.0 0.013" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.7854" upper="0.7854" effort="10" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Camera Link -->
  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="camera_tilt_link"/>
    <child link="camera_link"/>
    <origin xyz="0.030 0.0 0.014" rpy="0 0 0"/>
  </joint>

  <!-- Camera optical frame (Z forward, X right, Y down) -->
  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ========== IMU ========== -->
  <link name="imu_link"/>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.0275" rpy="0 0 0"/>  <!-- 6.5cm from floor (base_link is at wheel_radius=3.75cm) -->
  </joint>

  <!-- ========== REAR WHEELS (Passive) ========== -->
  <xacro:rear_wheel prefix="rear_left" y_offset="${track_width/2}" 
                    wheel_radius="${wheel_radius}" wheel_width="${wheel_width}"
                    rpy_yaw="${pi}"
                    x_offset="${-wheelbase/2}"
                    visual_y_offset="${(visual_track_width - track_width)/2}"/>
  <xacro:rear_wheel prefix="rear_right" y_offset="${-track_width/2}" 
                    wheel_radius="${wheel_radius}" wheel_width="${wheel_width}"
                    rpy_yaw="0"
                    x_offset="${-wheelbase/2}"
                    visual_y_offset="${-(visual_track_width - track_width)/2}"/>

  <!-- ========== FRONT WHEELS (Steering + Drive) ========== -->
  <xacro:front_wheel prefix="front_left" y_offset="${track_width/2}"
                     wheel_radius="${wheel_radius}" wheel_width="${wheel_width}"
                     x_offset="${wheelbase/2}"
                     rpy_yaw="${pi}"
                     visual_y_offset="${(visual_track_width - track_width)/2}"/>
  <xacro:front_wheel prefix="front_right" y_offset="${-track_width/2}"
                     wheel_radius="${wheel_radius}" wheel_width="${wheel_width}"
                     x_offset="${wheelbase/2}"
                     rpy_yaw="0"
                     visual_y_offset="${-(visual_track_width - track_width)/2}"/>

</robot>
