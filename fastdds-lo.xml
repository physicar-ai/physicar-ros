<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Fast DDS profile that pins all RTPS traffic to the loopback interface (lo).

  Why:
    * Container ROS nodes run as root; host-side user apps run as 'physicar'.
      The default Fast DDS shared-memory transport mmap()s files that aren't
      readable across UIDs, so cross-UID delivery silently drops.
    * ROS_AUTOMATIC_DISCOVERY_RANGE=LOCALHOST in Jazzy ends up on the same
      code path as the legacy ROS_LOCALHOST_ONLY=1 and trips over the
      container's PID namespace, breaking discovery.
    * We need SUBNET-style discovery (multicast on lo) but must not leak
      onto the WiFi NIC, otherwise kits on the same network see each other.

  This profile gives us:
    * UDPv4-only transport (no SHM, works across UIDs).
    * interfaceWhiteList = 127.0.0.1, so all SPDP/EDP multicast and RTPS
      unicast is bound to lo only — never escapes the box.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

  <transport_descriptors>
    <transport_descriptor>
      <transport_id>udp_lo</transport_id>
      <type>UDPv4</type>
      <interfaceWhiteList>
        <address>127.0.0.1</address>
      </interfaceWhiteList>
    </transport_descriptor>
  </transport_descriptors>

  <participant profile_name="lo_only_participant" is_default_profile="true">
    <rtps>
      <userTransports>
        <transport_id>udp_lo</transport_id>
      </userTransports>
      <useBuiltinTransports>false</useBuiltinTransports>
    </rtps>
  </participant>

</profiles>
